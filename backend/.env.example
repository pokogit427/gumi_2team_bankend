ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./localhub.db
# CORS 허용 origin 목록(쉼표로 구분). 우선순위: ALLOWED_ORIGINS > CORS_ORIGINS
# 예: ALLOWED_ORIGINS=http://localhost:5173,https://your-app.netlify.app
CORS_ORIGINS=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
# OpenAI API key (optional) - set in local `.env` or deployment environment
OPENAI_API_KEY=
